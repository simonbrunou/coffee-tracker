# Local development (SQLite file)
DATABASE_URL="file:./dev.db"

# Production (Turso) — uncomment and fill in after creating a Turso database
# DATABASE_URL="libsql://your-db-name-your-username.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# Auth — generate with: npx auth secret
AUTH_SECRET="generate-a-secure-secret-here"
